-- PAGE: TELEPORT
-- ============================================================
local tpPage = newPage("TELEPORT")

-- selected display
local selFrame = Instance.new("Frame", tpPage)
selFrame.Size             = UDim2.new(1,-24,0,56)
selFrame.Position         = UDim2.new(0,12,0,10)
selFrame.BackgroundColor3 = C.card
selFrame.BorderSizePixel  = 0
corner(selFrame, 10)
stroke(selFrame, C.border, 1)

local avatarImg = Instance.new("ImageLabel", selFrame)
avatarImg.Size=UDim2.new(0,40,0,40); avatarImg.Position=UDim2.new(0,8,0.5,-20)
avatarImg.BackgroundColor3=C.panel; avatarImg.BorderSizePixel=0
avatarImg.Image=""; corner(avatarImg,8)

local selName = Instance.new("TextLabel", selFrame)
selName.Size=UDim2.new(1,-62,0,18); selName.Position=UDim2.new(0,56,0,10)
selName.BackgroundTransparency=1; selName.Text="Pilih player..."
selName.Font=Enum.Font.GothamBold; selName.TextSize=13
selName.TextColor3=C.accent; selName.TextXAlignment=Enum.TextXAlignment.Left
selName.TextTruncate=Enum.TextTruncate.AtEnd

local selDisp = Instance.new("TextLabel", selFrame)
selDisp.Size=UDim2.new(1,-62,0,14); selDisp.Position=UDim2.new(0,56,0,30)
selDisp.BackgroundTransparency=1; selDisp.Text=""
selDisp.Font=Enum.Font.Gotham; selDisp.TextSize=11
selDisp.TextColor3=C.dim; selDisp.TextXAlignment=Enum.TextXAlignment.Left

local function updateSelDisplay(p)
    if not p then
        selName.Text="Pilih player..."; selDisp.Text=""; avatarImg.Image=""; return
    end
    selName.Text="@"..p.Name; selDisp.Text=p.DisplayName
    task.spawn(function()
        local ok,t=pcall(function()
            return Players:GetUserThumbnailAsync(p.UserId,Enum.ThumbnailType.HeadShot,Enum.ThumbnailSize.Size100x100)
        end)
        if ok then avatarImg.Image=t end
    end)
end

-- scroll list
local tpScroll = Instance.new("ScrollingFrame", tpPage)
tpScroll.Size=UDim2.new(1,-24,1,-170); tpScroll.Position=UDim2.new(0,12,0,76)
tpScroll.BackgroundColor3=C.panel; tpScroll.BorderSizePixel=0
tpScroll.ScrollBarThickness=3; tpScroll.ScrollBarImageColor3=C.border
tpScroll.CanvasSize=UDim2.new(0,0,0,0)
corner(tpScroll,10); stroke(tpScroll,C.border,1)

local tpListLayout=Instance.new("UIListLayout",tpScroll)
tpListLayout.Padding=UDim.new(0,4); tpListLayout.SortOrder=Enum.SortOrder.Name
local tpPad=Instance.new("UIPadding",tpScroll)
tpPad.PaddingTop=UDim.new(0,6); tpPad.PaddingLeft=UDim.new(0,6); tpPad.PaddingRight=UDim.new(0,6)

tpListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    tpScroll.CanvasSize=UDim2.new(0,0,0,tpListLayout.AbsoluteContentSize.Y+12)
end)

-- action buttons
local tpBtn=Instance.new("TextButton",tpPage)
tpBtn.Size=UDim2.new(1,-24,0,36); tpBtn.Position=UDim2.new(0,12,1,-86)
tpBtn.BackgroundColor3=Color3.fromRGB(200,200,210); tpBtn.BorderSizePixel=0
tpBtn.Text="TELEPORT"; tpBtn.Font=Enum.Font.GothamBold; tpBtn.TextSize=13
tpBtn.TextColor3=C.bg; corner(tpBtn,10)

local turunBtn=Instance.new("TextButton",tpPage)
turunBtn.Size=UDim2.new(1,-24,0,36); turunBtn.Position=UDim2.new(0,12,1,-44)
turunBtn.BackgroundColor3=Color3.fromRGB(30,30,38); turunBtn.BorderSizePixel=0
turunBtn.Text="TURUN"; turunBtn.Font=Enum.Font.GothamBold; turunBtn.TextSize=13
turunBtn.TextColor3=C.dim; corner(turunBtn,10); stroke(turunBtn,C.border,1)

local function updateTurunBtn()
    if hasTPed then
        tween(turunBtn,{BackgroundColor3=C.green},0.15)
        turunBtn.TextColor3=C.bg
    else
        tween(turunBtn,{BackgroundColor3=Color3.fromRGB(30,30,38)},0.15)
        turunBtn.TextColor3=C.dim
    end
end

tpBtn.MouseButton1Click:Connect(function()
    if not selectedTpPlayer then return end
    doTeleport()
    updateTurunBtn()
    tween(tpBtn,{BackgroundColor3=C.green},0.1)
    task.delay(0.2,function() tween(tpBtn,{BackgroundColor3=Color3.fromRGB(200,200,210)},0.2) end)
end)
turunBtn.MouseButton1Click:Connect(function()
    doTurun(); updateTurunBtn()
end)

-- player card builder
local playerCards = {}
local function clearTPList()
    for _,c in pairs(playerCards) do c:Destroy() end
    playerCards={}
end
local function buildTPCard(p)
    if p==player then return end
    local card=Instance.new("TextButton",tpScroll)
    card.Size=UDim2.new(1,0,0,48); card.BackgroundColor3=C.card
    card.BorderSizePixel=0; card.Text=""; card.AutoButtonColor=false
    corner(card,8)
    local img=Instance.new("ImageLabel",card)
    img.Size=UDim2.new(0,32,0,32); img.Position=UDim2.new(0,8,0.5,-16)
    img.BackgroundColor3=C.panel; img.BorderSizePixel=0; img.Image=""
    corner(img,6)
    task.spawn(function()
        local ok,t=pcall(function()
            return Players:GetUserThumbnailAsync(p.UserId,Enum.ThumbnailType.HeadShot,Enum.ThumbnailSize.Size48x48)
        end)
        if ok then img.Image=t end
    end)
    local uname=Instance.new("TextLabel",card)
    uname.Size=UDim2.new(1,-52,0,16); uname.Position=UDim2.new(0,48,0,8)
    uname.BackgroundTransparency=1; uname.Text="@"..p.Name
    uname.Font=Enum.Font.GothamBold; uname.TextSize=12; uname.TextColor3=C.accent
    uname.TextXAlignment=Enum.TextXAlignment.Left; uname.TextTruncate=Enum.TextTruncate.AtEnd
    local dname=Instance.new("TextLabel",card)
    dname.Size=UDim2.new(1,-52,0,14); dname.Position=UDim2.new(0,48,0,26)
    dname.BackgroundTransparency=1; dname.Text=p.DisplayName
    dname.Font=Enum.Font.Gotham; dname.TextSize=11; dname.TextColor3=C.dim
    dname.TextXAlignment=Enum.TextXAlignment.Left; dname.TextTruncate=Enum.TextTruncate.AtEnd
    card.MouseButton1Click:Connect(function()
        for _,c in pairs(playerCards) do tween(c,{BackgroundColor3=C.card},0.1) end
        tween(card,{BackgroundColor3=Color3.fromRGB(32,32,42)},0.1)
        selectedTpPlayer=p; hasTPed=false; stopFollow()
        updateSelDisplay(p); updateTurunBtn()
    end)
    table.insert(playerCards,card)
end
local function rebuildTPList()
    clearTPList()
    for _,p in ipairs(Players:GetPlayers()) do buildTPCard(p) end
end

Players.PlayerAdded:Connect(function(p)
    buildTPCard(p)
end)
Players.PlayerRemoving:Connect(function(p)
    if selectedTpPlayer==p then
        selectedTpPlayer=nil; hasTPed=false; stopFollow()
        updateSelDisplay(nil); updateTurunBtn()
    end
    rebuildTPList()
end)

rebuildTPList()
updateTurunBtn()

-- ============================================================
-- OPEN / CLOSE
-- ============================================================
local isOpen = true

local function openMenu()
    isOpen = true
    mainFrame.Visible = true
    shadow.Visible    = true
    pill.Visible      = false
    mainFrame.Size    = UDim2.new(0,0,0,0)
    shadow.Size       = UDim2.new(0,0,0,0)
    tween(mainFrame, {Size=UDim2.new(0,WIN_W,0,WIN_H)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    tween(shadow,    {Size=UDim2.new(0,WIN_W+16,0,WIN_H+16)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    playMusic()
end

local function closeMenu()
    isOpen = false
    tween(mainFrame, {Size=UDim2.new(0,WIN_W,0,0)}, 0.2)
    tween(shadow,    {Size=UDim2.new(0,WIN_W+16,0,0)}, 0.2)
    task.delay(0.22, function()
        mainFrame.Visible = false
        shadow.Visible    = false
        pill.Visible      = true
    end)
end

closeBtn.MouseButton1Click:Connect(closeMenu)
pillBtn.MouseButton1Click:Connect(openMenu)

-- Initial open animation
mainFrame.Size  = UDim2.new(0,0,0,0)
shadow.Size     = UDim2.new(0,0,0,0)
task.wait(0.1)
openMenu()

-- Default to BASIC page
showPage("BASIC")
setSideActive("BASIC")

print("[ NORVEX ] Loaded - by Nazam")
