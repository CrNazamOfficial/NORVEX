tpPad.PaddingRight = UDim.new(0, 4)

-- TP / Turun buttons
local tpBtn = Instance.new("TextButton", tpPanel)
tpBtn.Size = UDim2.new(0.46, 0, 0, 28)
tpBtn.Position = UDim2.new(0.03, 0, 1, -34)
tpBtn.BackgroundColor3 = C3
tpBtn.BorderSizePixel = 0
tpBtn.Text = "Teleport"
tpBtn.Font = Enum.Font.GothamBold
tpBtn.TextSize = 11
tpBtn.TextColor3 = C2
Instance.new("UICorner", tpBtn).CornerRadius = UDim.new(0, 7)

local turunBtn = Instance.new("TextButton", tpPanel)
turunBtn.Size = UDim2.new(0.46, 0, 0, 28)
turunBtn.Position = UDim2.new(0.51, 0, 1, -34)
turunBtn.BackgroundColor3 = Color3.fromRGB(80, 70, 68)
turunBtn.BorderSizePixel = 0
turunBtn.Text = "Turun"
turunBtn.Font = Enum.Font.GothamBold
turunBtn.TextSize = 11
turunBtn.TextColor3 = C1
Instance.new("UICorner", turunBtn).CornerRadius = UDim.new(0, 7)

local function updateTurunBtn()
    if hasTPed then
        TweenService:Create(turunBtn, TweenInfo.new(0.15), {BackgroundColor3 = C3}):Play()
        turunBtn.TextColor3 = C2
    else
        TweenService:Create(turunBtn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(80, 70, 68)}):Play()
        turunBtn.TextColor3 = C1
    end
end

local playerCards = {}

local function clearCards()
    for _, c in pairs(playerCards) do c:Destroy() end
    playerCards = {}
end

local function buildCard(p)
    if p == player then return end
    local card = Instance.new("TextButton")
    card.Size = UDim2.new(1, 0, 0, 36)
    card.BackgroundColor3 = C2
    card.BackgroundTransparency = 0.3
    card.BorderSizePixel = 0
    card.Text = ""
    card.AutoButtonColor = false
    card.Parent = tpScroll
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 7)

    local img = Instance.new("ImageLabel", card)
    img.Size = UDim2.new(0, 26, 0, 26)
    img.Position = UDim2.new(0, 5, 0.5, -13)
    img.BackgroundColor3 = C2
    img.BorderSizePixel = 0
    img.Image = ""
    Instance.new("UICorner", img).CornerRadius = UDim.new(0, 5)

    task.spawn(function()
        local ok, thumb = pcall(function()
            return Players:GetUserThumbnailAsync(p.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
        end)
        if ok then img.Image = thumb end
    end)

    local uname = Instance.new("TextLabel", card)
    uname.Size = UDim2.new(1, -40, 1, 0)
    uname.Position = UDim2.new(0, 36, 0, 0)
    uname.BackgroundTransparency = 1
    uname.Text = p.Name
    uname.Font = Enum.Font.GothamBold
    uname.TextSize = 11
    uname.TextColor3 = C1
    uname.TextXAlignment = Enum.TextXAlignment.Left
    uname.TextTruncate = Enum.TextTruncate.AtEnd

    card.MouseButton1Click:Connect(function()
        for _, c in pairs(playerCards) do
            TweenService:Create(c, TweenInfo.new(0.1), {BackgroundTransparency = 0.3}):Play()
        end
        TweenService:Create(card, TweenInfo.new(0.1), {BackgroundTransparency = 0}):Play()
        selectedPlayer = p
        hasTPed = false
        stopFollow()
        selName.Text = p.Name
        task.spawn(function()
            local ok, thumb = pcall(function()
                return Players:GetUserThumbnailAsync(p.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
            end)
            selAvatar.Image = ok and thumb or ""
        end)
        updateTurunBtn()
    end)

    table.insert(playerCards, card)
end

local function rebuildList()
    clearCards()
    for _, p in ipairs(Players:GetPlayers()) do buildCard(p) end
    tpScroll.CanvasSize = UDim2.new(0, 0, 0, tpLayout.AbsoluteContentSize.Y + 8)
end

tpLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    tpScroll.CanvasSize = UDim2.new(0, 0, 0, tpLayout.AbsoluteContentSize.Y + 8)
end)

Players.PlayerAdded:Connect(function(p) buildCard(p) end)
Players.PlayerRemoving:Connect(function(p)
    if selectedPlayer == p then
        selectedPlayer = nil
        hasTPed = false
        stopFollow()
        selName.Text = "Pilih player..."
        selAvatar.Image = ""
        updateTurunBtn()
    end
    rebuildList()
end)

tpBtn.MouseButton1Click:Connect(function()
    if not selectedPlayer then return end
    doTeleport()
    TweenService:Create(tpBtn, TweenInfo.new(0.08), {BackgroundColor3 = C1}):Play()
    task.delay(0.12, function()
        TweenService:Create(tpBtn, TweenInfo.new(0.15), {BackgroundColor3 = C3}):Play()
    end)
    updateTurunBtn()
end)

turunBtn.MouseButton1Click:Connect(function()
    doTurun()
    updateTurunBtn()
end)

rebuildList()
updateTurunBtn()

