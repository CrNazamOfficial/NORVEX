local basicPage = newPage("BASIC")

local bScroll = Instance.new("ScrollingFrame", basicPage)
bScroll.Size             = UDim2.new(1,0,1,0)
bScroll.BackgroundTransparency = 1
bScroll.BorderSizePixel  = 0
bScroll.ScrollBarThickness = 3
bScroll.ScrollBarImageColor3 = C.border
bScroll.CanvasSize       = UDim2.new(0,0,0,0)

local bLayout = Instance.new("UIListLayout", bScroll)
bLayout.Padding   = UDim.new(0,6)
bLayout.SortOrder = Enum.SortOrder.LayoutOrder

local bPad = Instance.new("UIPadding", bScroll)
bPad.PaddingTop    = UDim.new(0,12)
bPad.PaddingBottom = UDim.new(0,12)
bPad.PaddingLeft   = UDim.new(0,0)
bPad.PaddingRight  = UDim.new(0,0)

bLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    bScroll.CanvasSize = UDim2.new(0,0,0,bLayout.AbsoluteContentSize.Y+24)
end)

-- helper: card inside list layout
local function listCard(parent, order)
    local c = Instance.new("Frame", parent)
    c.Size             = UDim2.new(1,-24,0,44)
    c.BackgroundColor3 = C.card
    c.BorderSizePixel  = 0
    c.LayoutOrder      = order
    corner(c, 10)
    stroke(c, C.border, 1)
    local pad = Instance.new("UIPadding", c)
    pad.PaddingLeft = UDim.new(0,12)
    return c
end

