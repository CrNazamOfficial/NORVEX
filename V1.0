-- ============================================================
-- PAGE SYSTEM
-- ============================================================
local pages      = {}
local activePage = nil

local function showPage(name)
    for n, pg in pairs(pages) do
        pg.Visible = (n == name)
    end
    activePage = name
end

local function newPage(name)
    local f = Instance.new("Frame", contentArea)
    f.Size             = UDim2.new(1,0,1,0)
    f.BackgroundTransparency = 1
    f.BorderSizePixel  = 0
    f.Visible          = false
    pages[name] = f
    return f
end

-- ============================================================
-- SIDEBAR BUTTONS
-- ============================================================
local sideButtons = {}

local navItems = {
    {name = "BASIC",    label = "BASIC",    order = 1},
    {name = "TELEPORT", label = "TELEPORT", order = 2},
}

local function setSideActive(name)
    for n, btn in pairs(sideButtons) do
        if n == name then
            tween(btn, {BackgroundColor3 = Color3.fromRGB(28,28,36)}, 0.15)
            btn.TextColor3 = C.white
        else
            tween(btn, {BackgroundColor3 = Color3.fromRGB(0,0,0)}, 0.15)
            btn.TextColor3 = C.dim
        end
    end
end

for _, item in ipairs(navItems) do
    local btn = Instance.new("TextButton", sidebar)
    btn.Size             = UDim2.new(1, 0, 0, 36)
    btn.BackgroundColor3 = Color3.fromRGB(0,0,0)
    btn.BorderSizePixel  = 0
    btn.Text             = item.label
    btn.Font             = Enum.Font.GothamBold
    btn.TextSize         = 12
    btn.TextColor3       = C.dim
    btn.LayoutOrder      = item.order
    corner(btn, 8)

    btn.MouseButton1Click:Connect(function()
        showPage(item.name)
        setSideActive(item.name)
    end)

    sideButtons[item.name] = btn
end

-- ============================================================
-- TOGGLE COMPONENT FACTORY
-- ============================================================
local function makeToggle(parent, labelText, yPos, onToggle)
    local card = Instance.new("Frame", parent)
    card.Size             = UDim2.new(1, -24, 0, 44)
    card.Position         = UDim2.new(0, 12, 0, yPos)
    card.BackgroundColor3 = C.card
    card.BorderSizePixel  = 0
    corner(card, 10)
    stroke(card, C.border, 1)

    local lbl = Instance.new("TextLabel", card)
    lbl.Size               = UDim2.new(1,-80,1,0)
    lbl.Position           = UDim2.new(0,14,0,0)
    lbl.BackgroundTransparency = 1
    lbl.Text               = labelText
    lbl.Font               = Enum.Font.GothamBold
    lbl.TextSize           = 13
    lbl.TextColor3         = C.accent
    lbl.TextXAlignment     = Enum.TextXAlignment.Left

    -- status dot
    local dot = Instance.new("Frame", card)
    dot.Size             = UDim2.new(0,8,0,8)
    dot.Position         = UDim2.new(1,-62,0.5,-4)
    dot.BackgroundColor3 = C.red
    dot.BorderSizePixel  = 0
    corner(dot, 4)

    -- track
    local track = Instance.new("Frame", card)
    track.Size             = UDim2.new(0,44,0,24)
    track.Position         = UDim2.new(1,-52,0.5,-12)
    track.BackgroundColor3 = Color3.fromRGB(35,35,42)
    track.BorderSizePixel  = 0
    corner(track, 12)
    stroke(track, C.border, 1)

    local knob = Instance.new("Frame", track)
    knob.Size             = UDim2.new(0,18,0,18)
    knob.Position         = UDim2.new(0,3,0.5,-9)
    knob.BackgroundColor3 = C.dim
    knob.BorderSizePixel  = 0
    corner(knob, 9)

    local clickBtn = Instance.new("TextButton", track)
    clickBtn.Size                 = UDim2.new(1,0,1,0)
    clickBtn.BackgroundTransparency = 1
    clickBtn.Text                 = ""

    local state = false

    local function updateVisual(on)
        local ti = TweenInfo.new(0.18, Enum.EasingStyle.Quad)
        if on then
            TweenService:Create(track, ti, {BackgroundColor3 = Color3.fromRGB(200,200,210)}):Play()
            TweenService:Create(knob,  ti, {Position = UDim2.new(0,23,0.5,-9), BackgroundColor3 = C.bg}):Play()
            TweenService:Create(dot,   ti, {BackgroundColor3 = C.green}):Play()
        else
            TweenService:Create(track, ti, {BackgroundColor3 = Color3.fromRGB(35,35,42)}):Play()
            TweenService:Create(knob,  ti, {Position = UDim2.new(0,3,0.5,-9), BackgroundColor3 = C.dim}):Play()
            TweenService:Create(dot,   ti, {BackgroundColor3 = C.red}):Play()
        end
    end

    clickBtn.MouseButton1Click:Connect(function()
        state = not state
        updateVisual(state)
        onToggle(state)
    end)

    return card, function(forcedState)
        state = forcedState
        updateVisual(forcedState)
    end
end

