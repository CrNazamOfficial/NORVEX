local function setSpeedSwitch(on)
    speedEnabled = on
    local t = TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    if on then
        TweenService:Create(spTrack, t, {BackgroundColor3 = C3}):Play()
        TweenService:Create(spKnob, t, {Position = UDim2.new(0, 25, 0.5, -9)}):Play()
        TweenService:Create(spLabel, t, {TextColor3 = C3}):Play()
    else
        TweenService:Create(spTrack, t, {BackgroundColor3 = Color3.fromRGB(80, 70, 68)}):Play()
        TweenService:Create(spKnob, t, {Position = UDim2.new(0, 3, 0.5, -9)}):Play()
        TweenService:Create(spLabel, t, {TextColor3 = C1}):Play()
    end
    applySpeed()
end

spToggleBtn.MouseButton1Click:Connect(function()
    setSpeedSwitch(not speedEnabled)
end)

spMinus.MouseButton1Click:Connect(function()
    speedValue = math.max(speedValue - 5, 1)
    updateSpeedDisplay()
    if speedEnabled then applySpeed() end
end)

spPlus.MouseButton1Click:Connect(function()
    speedValue = math.min(speedValue + 5, 500)
    updateSpeedDisplay()
    if speedEnabled then applySpeed() end
end)

makeSectionLabel("  PLAYER", 8)

