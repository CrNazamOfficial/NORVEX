-- =====================
-- HELPER: TOGGLE ROW
-- =====================
local function makeToggleRow(labelText, order)
    local row = Instance.new("Frame", contentArea)
    row.Size = UDim2.new(1, 0, 0, 44)
    row.BackgroundColor3 = C2
    row.BackgroundTransparency = 0.4
    row.BorderSizePixel = 0
    row.LayoutOrder = order
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 10)

    local rowStroke = Instance.new("UIStroke", row)
    rowStroke.Color = C1
    rowStroke.Transparency = 0.7
    rowStroke.Thickness = 1

    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(0.6, 0, 1, 0)
    lbl.Position = UDim2.new(0, 12, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 12
    lbl.TextColor3 = C1
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    -- Switch track
    local track = Instance.new("Frame", row)
    track.Size = UDim2.new(0, 46, 0, 24)
    track.Position = UDim2.new(1, -54, 0.5, -12)
    track.BackgroundColor3 = Color3.fromRGB(80, 70, 68)
    track.BorderSizePixel = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.Position = UDim2.new(0, 3, 0.5, -9)
    knob.BackgroundColor3 = C1
    knob.BorderSizePixel = 0
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local switchBtn = Instance.new("TextButton", track)
    switchBtn.Size = UDim2.new(1, 0, 1, 0)
    switchBtn.BackgroundTransparency = 1
    switchBtn.Text = ""

    local isOn = false
    local function setSwitch(state, callback)
        isOn = state
        local t = TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        if state then
            TweenService:Create(track, t, {BackgroundColor3 = C3}):Play()
            TweenService:Create(knob, t, {Position = UDim2.new(0, 25, 0.5, -9)}):Play()
            TweenService:Create(lbl, t, {TextColor3 = C3}):Play()
        else
            TweenService:Create(track, t, {BackgroundColor3 = Color3.fromRGB(80, 70, 68)}):Play()
            TweenService:Create(knob, t, {Position = UDim2.new(0, 3, 0.5, -9)}):Play()
            TweenService:Create(lbl, t, {TextColor3 = C1}):Play()
        end
        if callback then callback(state) end
    end

    return row, switchBtn, setSwitch, function() return isOn end
end

-- =====================
-- HELPER: SECTION LABEL
-- =====================
local function makeSectionLabel(text, order)
    local f = Instance.new("Frame", contentArea)
    f.Size = UDim2.new(1, 0, 0, 20)
    f.BackgroundTransparency = 1
    f.BorderSizePixel = 0
    f.LayoutOrder = order
    local l = Instance.new("TextLabel", f)
    l.Size = UDim2.new(1, 0, 1, 0)
    l.BackgroundTransparency = 1
    l.Text = text
    l.Font = Enum.Font.GothamBold
    l.TextSize = 10
    l.TextColor3 = C3
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.Position = UDim2.new(0, 4, 0, 0)
    return f
end

-- =====================
-- FITUR STATES
-- =====================
local noClipEnabled = false
local noClipConn = nil

local infJumpEnabled = false
local jumpConn = nil

local speedEnabled = false
local speedValue = 16

local flyEnabled = false
local flyConn = nil
local bodyVel = nil
local bodyGyr = nil

local airWalkEnabled = false
local airPlatform = nil
local airLockedY = nil
local airWasInAir = false

local selectedPlayer = nil
local hasTPed = false
local followConn = nil

-- =====================
-- NOCLIP LOGIC
-- =====================
local function setNoClip(en)
    noClipEnabled = en
    if en then
        if noClipConn then return end
        noClipConn = RunService.Stepped:Connect(function()
            if player.Character then
                for _, p in pairs(player.Character:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end
        end)
    else
        if noClipConn then noClipConn:Disconnect(); noClipConn = nil end
        if player.Character then
            for _, p in pairs(player.Character:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = true end
            end
        end
    end
end

-- =====================
-- INF JUMP LOGIC
-- =====================
local function setInfJump(en)
    infJumpEnabled = en
    if en then
        if jumpConn then return end
        jumpConn = UserInputService.JumpRequest:Connect(function()
            if player.Character then
                local h = player.Character:FindFirstChildOfClass("Humanoid")
                if h and h.Health > 0 then
                    h:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end
        end)
    else
        if jumpConn then jumpConn:Disconnect(); jumpConn = nil end
    end
end

-- =====================
-- SPEED LOGIC
-- =====================
local function applySpeed()
    if player.Character then
        local h = player.Character:FindFirstChildOfClass("Humanoid")
        if h then h.WalkSpeed = speedEnabled and speedValue or 16 end
    end
end

-- =====================
-- FLY LOGIC
-- =====================
local function enableFly()
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not root or not hum then return end
    hum.PlatformStand = true

    bodyVel = Instance.new("BodyVelocity")
    bodyVel.Velocity = Vector3.zero
    bodyVel.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bodyVel.Parent = root

    bodyGyr = Instance.new("BodyGyro")
    bodyGyr.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    bodyGyr.D = 100
    bodyGyr.P = 1e4
    bodyGyr.Parent = root

    if flyConn then flyConn:Disconnect() end
    flyConn = RunService.RenderStepped:Connect(function()
        if not flyEnabled or not bodyVel or not bodyGyr then return end
        local char2 = player.Character
        if not char2 then return end
        local root2 = char2:FindFirstChild("HumanoidRootPart")
        local hum2 = char2:FindFirstChildOfClass("Humanoid")
        if not root2 or not hum2 then return end

        local cam = workspace.CurrentCamera
        local camCF = cam.CFrame
        local camY = math.atan2(-camCF.LookVector.X, -camCF.LookVector.Z)
        local camPitch = math.asin(math.clamp(camCF.LookVector.Y, -1, 1))
        local camRight = camCF.RightVector
        local camFwd = Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z)
        if camFwd.Magnitude > 0.01 then camFwd = camFwd.Unit end

        local rawInput = Vector2.zero
        if UserInputService.KeyboardEnabled then
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then rawInput = rawInput + Vector2.new(0, 1) end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then rawInput = rawInput + Vector2.new(0, -1) end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then rawInput = rawInput + Vector2.new(-1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then rawInput = rawInput + Vector2.new(1, 0) end
            if rawInput.Magnitude > 1 then rawInput = rawInput.Unit end
        else
            local md = hum2.MoveDirection
            local dotFwd = md:Dot(camFwd)
            local dotRight = md:Dot(camRight)
            rawInput = Vector2.new(dotRight, dotFwd)
        end

        if rawInput.Magnitude < 0.1 then
            bodyVel.Velocity = Vector3.zero
        else
            local moveDir = camFwd * rawInput.Y + camRight * rawInput.X
            local pitchComp = camCF.LookVector.Y
            local finalDir = Vector3.new(moveDir.X, pitchComp, moveDir.Z)
            if finalDir.Magnitude > 0 then finalDir = finalDir.Unit end
            bodyVel.Velocity = finalDir * 50 * rawInput.Magnitude
        end

        bodyGyr.CFrame = CFrame.new(Vector3.zero) * CFrame.Angles(0, camY, 0) * CFrame.Angles(camPitch, 0, 0)
    end)
end

local function disableFly()
    if flyConn then flyConn:Disconnect(); flyConn = nil end
    local char = player.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.PlatformStand = false end
    end
    if bodyVel then bodyVel:Destroy(); bodyVel = nil end
    if bodyGyr then bodyGyr:Destroy(); bodyGyr = nil end
end

-- =====================
-- AIRWALK LOGIC
-- =====================
local function createPlatform()
    if airPlatform then airPlatform:Destroy() end
    airPlatform = Instance.new("Part")
    airPlatform.Size = Vector3.new(60, 0.2, 60)
    airPlatform.Anchored = true
    airPlatform.CanCollide = true
    airPlatform.Transparency = 1
    airPlatform.CastShadow = false
    airPlatform.Name = "NORVEX_AirPlatform"
    airPlatform.Parent = workspace
end

local function removePlatform()
    if airPlatform then airPlatform:Destroy(); airPlatform = nil end
    airLockedY = nil
    airWasInAir = false
end

RunService.RenderStepped:Connect(function()
    if not airWalkEnabled then return end
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not root or not hum then return end
    if not airPlatform then createPlatform() end

    local pos = root.Position
    local velY = root.AssemblyLinearVelocity.Y
    local feetY = pos.Y - 3.1
    local isJumping = velY > 0.5
    local isFalling = velY < -0.5
    local isInAir = hum:GetState() == Enum.HumanoidStateType.Freefall
                 or hum:GetState() == Enum.HumanoidStateType.Jumping

    if isJumping then
        airWasInAir = true
        airPlatform.CFrame = CFrame.new(pos.X, feetY - 50, pos.Z)
        airLockedY = nil
    elseif airWasInAir and isFalling then
        if airLockedY == nil then airLockedY = feetY end
        airPlatform.CFrame = CFrame.new(pos.X, airLockedY, pos.Z)
    elseif not isInAir and not isJumping then
        airWasInAir = false
        airLockedY = nil
        airPlatform.CFrame = CFrame.new(pos.X, feetY, pos.Z)
    else
        if airLockedY then
            airPlatform.CFrame = CFrame.new(pos.X, airLockedY, pos.Z)
        else
            airPlatform.CFrame = CFrame.new(pos.X, feetY, pos.Z)
        end
    end
end)

-- =====================
-- TELEPORT LOGIC
-- =====================
local function getPosBehind(targetChar)
    local root = targetChar:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    return root.CFrame * CFrame.new(0, 0, 4)
end

local function stopFollow()
    if followConn then followConn:Disconnect(); followConn = nil end
end

local function startFollow(targetPlayer)
    stopFollow()
    followConn = RunService.Heartbeat:Connect(function()
        local myChar = player.Character
        local tChar = targetPlayer.Character
        if not myChar or not tChar then return end
        local myRoot = myChar:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        local behind = getPosBehind(tChar)
        if behind then myRoot.CFrame = behind end
    end)
end

local function doTeleport()
    if not selectedPlayer then return end
    local tChar = selectedPlayer.Character
    if not tChar then return end
    local behind = getPosBehind(tChar)
    if not behind then return end
    local myChar = player.Character
    if not myChar then return end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    myRoot.CFrame = behind
    hasTPed = true
    startFollow(selectedPlayer)
end

local function doTurun()
    if not hasTPed then return end
    stopFollow()
    local myChar = player.Character
    if myChar then
        local h = myChar:FindFirstChildOfClass("Humanoid")
        if h then h.PlatformStand = false end
    end
    hasTPed = false
end

-- =====================
-- RESPAWN HANDLER
-- =====================
player.CharacterAdded:Connect(function()
    task.wait(0.4)
    -- Reset semua fitur
    if noClipEnabled then setNoClip(false) end
    if infJumpEnabled then
        infJumpEnabled = false
        if jumpConn then jumpConn:Disconnect(); jumpConn = nil end
    end
    if speedEnabled then
        speedEnabled = false
        applySpeed()
    end
    if flyEnabled then
        flyEnabled = false
        disableFly()
    end
    if airWalkEnabled then
        removePlatform()
    end
    if hasTPed then
        hasTPed = false
        stopFollow()
    end
end)

