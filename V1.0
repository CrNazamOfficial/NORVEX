    dot.Position=UDim2.new(1,-62,0.5/80*30,-4)
    dot.Position=UDim2.new(1,-62,0,11)
    dot.BackgroundColor3=C.red; dot.BorderSizePixel=0; corner(dot,4)
    local track=Instance.new("Frame",card); track.Size=UDim2.new(0,44,0,24)
    track.Position=UDim2.new(1,-52,0,3); track.BackgroundColor3=Color3.fromRGB(35,35,42)
    track.BorderSizePixel=0; corner(track,12); stroke(track,C.border,1)
    local knob=Instance.new("Frame",track); knob.Size=UDim2.new(0,18,0,18)
    knob.Position=UDim2.new(0,3,0.5,-9); knob.BackgroundColor3=C.dim; knob.BorderSizePixel=0; corner(knob,9)
    local cb=Instance.new("TextButton",track); cb.Size=UDim2.new(1,0,1,0)
    cb.BackgroundTransparency=1; cb.Text=""

    -- speed value display
    local speedVal = Instance.new("TextLabel", card)
    speedVal.Size=UDim2.new(0,80,0,22)
    speedVal.Position=UDim2.new(0,0,0,38)
    speedVal.BackgroundColor3=Color3.fromRGB(12,12,16)
    speedVal.BorderSizePixel=0
    speedVal.Text="SPD: "..tostring(_G.SpeedValue)
    speedVal.Font=Enum.Font.GothamBold; speedVal.TextSize=11
    speedVal.TextColor3=C.white
    corner(speedVal,6)

    local minusBtn=Instance.new("TextButton",card)
    minusBtn.Size=UDim2.new(0,50,0,22); minusBtn.Position=UDim2.new(0,86,0,38)
    minusBtn.BackgroundColor3=Color3.fromRGB(30,18,18); minusBtn.BorderSizePixel=0
    minusBtn.Text="- 5"; minusBtn.Font=Enum.Font.GothamBold; minusBtn.TextSize=11
    minusBtn.TextColor3=C.red; corner(minusBtn,6); stroke(minusBtn,C.border,1)

    local plusBtn=Instance.new("TextButton",card)
    plusBtn.Size=UDim2.new(0,50,0,22); plusBtn.Position=UDim2.new(0,142,0,38)
    plusBtn.BackgroundColor3=Color3.fromRGB(16,28,18); plusBtn.BorderSizePixel=0
    plusBtn.Text="+ 5"; plusBtn.Font=Enum.Font.GothamBold; plusBtn.TextSize=11
    plusBtn.TextColor3=C.green; corner(plusBtn,6); stroke(plusBtn,C.border,1)

    local function upV(on)
        local ti=TweenInfo.new(0.18,Enum.EasingStyle.Quad)
        if on then
            TweenService:Create(track,ti,{BackgroundColor3=Color3.fromRGB(200,200,210)}):Play()
            TweenService:Create(knob,ti,{Position=UDim2.new(0,23,0.5,-9),BackgroundColor3=C.bg}):Play()
            TweenService:Create(dot,ti,{BackgroundColor3=C.green}):Play()
        else
            TweenService:Create(track,ti,{BackgroundColor3=Color3.fromRGB(35,35,42)}):Play()
            TweenService:Create(knob,ti,{Position=UDim2.new(0,3,0.5,-9),BackgroundColor3=C.dim}):Play()
            TweenService:Create(dot,ti,{BackgroundColor3=C.red}):Play()
        end
    end
    cb.MouseButton1Click:Connect(function()
        _G.SpeedEnabled = not _G.SpeedEnabled
        applySpeed(); upV(_G.SpeedEnabled)
    end)
    minusBtn.MouseButton1Click:Connect(function()
        _G.SpeedValue=math.max(_G.SpeedValue-5,1)
        speedVal.Text="SPD: ".._G.SpeedValue
        if _G.SpeedEnabled then applySpeed() end
    end)
    plusBtn.MouseButton1Click:Connect(function()
        _G.SpeedValue=math.min(_G.SpeedValue+5,500)
        speedVal.Text="SPD: ".._G.SpeedValue
        if _G.SpeedEnabled then applySpeed() end
    end)
    player.CharacterAdded:Connect(function() task.wait(0.5); upV(_G.SpeedEnabled) end)
end

